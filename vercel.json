{
  "version": 2,
  "builds": [
    {
      "src": "api/blob-upload.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": { "maxDuration": 60 }
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' https://blob.vercel-storage.com https://*.public.blob.vercel-storage.com; font-src 'self'; object-src 'none'; frame-ancestors 'none'"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/blob-upload",
      "destination": "/api/blob-upload.js"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index.py"
    }
  ]
}
